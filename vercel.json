{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/vendor",
      "destination": "frontend/vendor-panel/vendor.html"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}